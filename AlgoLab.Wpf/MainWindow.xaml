<Window x:Class="AlgoLab.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AlgoLab"
        Height="900"
        Width="1300"
        MinHeight="700"
        MinWidth="1100"
        Background="#1E1E1E">

    <TabControl Background="#1E1E1E" BorderBrush="#1E1E1E">
        <TabItem Header="Сортировка">
            <Grid Margin="16">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#2A2A2A"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,12">
                    <WrapPanel VerticalAlignment="Center">

                        <TextBlock Text="Размер:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />

                        <TextBox x:Name="SizeTextBox"
                                 Width="60"
                                 Text="20"
                                 Margin="0,0,16,0" />

                        <TextBlock Text="Алгоритм:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />

                        <ComboBox x:Name="AlgorithmComboBox"
                                  Width="160"
                                  Margin="0,0,16,0" />

                        <TextBlock Text="Задержка:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />

                        <Slider x:Name="DelaySlider"
                                Width="180"
                                Minimum="50"
                                Maximum="1000"
                                Value="200"
                                TickFrequency="50"
                                IsSnapToTickEnabled="True"
                                ValueChanged="DelaySlider_ValueChanged"
                                Margin="0,0,8,0" />

                        <TextBlock x:Name="DelayValueText"
                                   Text="200 мс"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0" />

                        <Button x:Name="GenerateButton"
                                Content="Сгенерировать"
                                Click="GenerateButton_Click"
                                Margin="0,0,8,0"
                                Padding="12,6" />

                        <Button x:Name="StartButton"
                                Content="Старт"
                                Click="StartButton_Click"
                                Margin="0,0,16,0"
                                Padding="12,6" />

                        <TextBlock Text="Повторов:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />

                        <TextBox x:Name="RunsTextBox"
                                 Width="60"
                                 Text="50"
                                 Margin="0,0,16,0" />

                        <CheckBox x:Name="BubbleBenchmarkCheckBox"
                                  Content="Bubble"
                                  IsChecked="True"
                                  Foreground="White"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0" />

                        <CheckBox x:Name="QuickBenchmarkCheckBox"
                                  Content="Quick"
                                  IsChecked="True"
                                  Foreground="White"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0" />

                        <Button x:Name="BenchmarkButton"
                                Content="Исследование"
                                Click="BenchmarkButton_Click"
                                Padding="12,6" />
                    </WrapPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="#2A2A2A"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="InfoTextBlock"
                               Foreground="White"
                               Text="Готово к запуску" />
                </Border>

                <Border Grid.Row="2"
                        Background="#2A2A2A"
                        CornerRadius="10"
                        Padding="12">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="BarsItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Bottom" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="28"
                                          Height="390"
                                          Margin="2"
                                          VerticalAlignment="Bottom">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="360" />
                                            <RowDefinition Height="30" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Width="28"
                                                Height="{Binding Height}"
                                                VerticalAlignment="Bottom"
                                                Background="{Binding Fill}"
                                                CornerRadius="4,4,0,0" />

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Value}"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="3"
                        Background="#2A2A2A"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,12,0,0">
                    <DataGrid x:Name="BenchmarkDataGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              RowBackground="#2A2A2A"
                              AlternatingRowBackground="#313131"
                              Background="#2A2A2A"
                              Foreground="White"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#3A3A3A" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderBrush" Value="#505050" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>

                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="#505050" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#4F46E5" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <Style TargetType="DataGridRow">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="#2A2A2A" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#4F46E5" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Алгоритм"
                                                Binding="{Binding Name}"
                                                Width="*" />

                            <DataGridTextColumn Header="Повторов"
                                                Binding="{Binding RunsCount}"
                                                Width="90" />

                            <DataGridTextColumn Header="Средн. сравнений"
                                                Binding="{Binding AvgComparisons, StringFormat={}{0:F2}}"
                                                Width="140" />

                            <DataGridTextColumn Header="Средн. перестановок"
                                                Binding="{Binding AvgSwaps, StringFormat={}{0:F2}}"
                                                Width="150" />

                            <DataGridTextColumn Header="Средн. время, мс"
                                                Binding="{Binding AvgMs, StringFormat={}{0:F4}}"
                                                Width="140" />

                            <DataGridTextColumn Header="Мин, мс"
                                                Binding="{Binding MinMs, StringFormat={}{0:F4}}"
                                                Width="100" />

                            <DataGridTextColumn Header="Макс, мс"
                                                Binding="{Binding MaxMs, StringFormat={}{0:F4}}"
                                                Width="100" />

                            <DataGridTextColumn Header="Сумма, мс"
                                                Binding="{Binding TotalMs, StringFormat={}{0:F4}}"
                                                Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </TabItem>
        <TabItem Header="Поиск">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#2A2A2A"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,12">
                    <WrapPanel VerticalAlignment="Center">

                        <TextBlock Text="Размер:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <TextBox x:Name="SearchSizeTextBox"
                                 Width="60"
                                 Text="20"
                                 Margin="0,0,16,0"/>

                        <TextBlock Text="Алгоритм:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <ComboBox x:Name="SearchAlgorithmComboBox"
                                  Width="160"
                                  Margin="0,0,16,0"/>

                        <TextBlock Text="Цель:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <TextBox x:Name="SearchTargetTextBox"
                                 Width="70"
                                 Margin="0,0,8,0"/>

                        <Button x:Name="RandomTargetButton"
                                Content="Случайная цель"
                                Click="RandomTargetButton_Click"
                                Margin="0,0,16,0"
                                Padding="12,6"/>

                        <TextBlock Text="Задержка:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <Slider x:Name="SearchDelaySlider"
                                Width="180"
                                Minimum="50"
                                Maximum="1000"
                                Value="200"
                                TickFrequency="50"
                                IsSnapToTickEnabled="True"
                                ValueChanged="SearchDelaySlider_ValueChanged"
                                Margin="0,0,8,0"/>

                        <TextBlock x:Name="SearchDelayValueText"
                                   Text="200 мс"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>

                        <Button x:Name="GenerateSearchButton"
                                Content="Сгенерировать"
                                Click="GenerateSearchButton_Click"
                                Margin="0,0,8,0"
                                Padding="12,6"/>

                        <Button x:Name="StartSearchButton"
                                Content="Старт поиска"
                                Click="StartSearchButton_Click"
                                Padding="12,6"/>
                    </WrapPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="#2A2A2A"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="SearchInfoTextBlock"
                               Foreground="White"
                               Text="Готово к поиску"/>
                </Border>

                <Border Grid.Row="2"
                        Background="#2A2A2A"
                        CornerRadius="10"
                        Padding="12">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="SearchBarsItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Bottom"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="28"
                                          Height="390"
                                          Margin="2"
                                          VerticalAlignment="Bottom">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="360"/>
                                            <RowDefinition Height="30"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Width="28"
                                                Height="{Binding Height}"
                                                VerticalAlignment="Bottom"
                                                Background="{Binding Fill}"
                                                CornerRadius="4,4,0,0"/>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Value}"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Window>